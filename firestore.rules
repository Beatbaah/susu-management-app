rules_version = '2';

// Production Firestore rules for Excellent Susu.
//
// Architecture:
//   - Users authenticate with Firebase Email/Password Auth.
//   - Each user's Firestore document lives at users/{auth.uid} so
//     request.auth.uid == userId is the ownership test.
//   - Role is checked from Firebase Auth Custom Claims (request.auth.token.role)
//     set by the syncUserRole Cloud Function, with a Firestore doc fallback for
//     users who haven't had their claims synced yet (e.g. pending members).
//   - Audit logs are written by the writeAuditLog Cloud Function using the Admin
//     SDK — client writes are denied so logs cannot be forged or deleted.
//   - Anonymous auth is NOT permitted to write any data.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Real email/password (or other non-anonymous) authenticated user.
    function isRealAuth() {
      return signedIn() && !isAnonymous();
    }

    // Role resolution: prefer Custom Claims (fast, no extra read) and fall back
    // to the Firestore user doc for accounts that pre-date the syncUserRole function.
    function claimRole() {
      return request.auth.token.get('role', '');
    }

    function callerDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function docRole() {
      return callerDoc().data.role;
    }

    function callerRole() {
      return claimRole() != '' ? claimRole() : docRole();
    }

    function isAdmin() {
      return isRealAuth() && callerRole() == 'admin';
    }

    function isManager() {
      return isRealAuth() && callerRole() in ['admin', 'manager'];
    }

    function isStaff() {
      return isRealAuth() && callerRole() in ['admin', 'manager', 'collector'];
    }

    function isMember() {
      return isRealAuth() && callerRole() == 'member';
    }

    function ownsDoc(userId) {
      return isRealAuth() && request.auth.uid == userId;
    }

    function notSuspended() {
      return callerDoc().data.status != 'suspended';
    }

    // Deny attempts to escalate privileges via incoming write.
    function noRoleEscalation() {
      return !('role' in request.resource.data) ||
             request.resource.data.role == resource.data.role ||
             isAdmin();
    }

    // ── /users ───────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if ownsDoc(userId) || isStaff();
      // Self-registration path: allow any write that creates a pending member.
      // The role and status constraints prevent privilege escalation — only
      // staff can later approve/change status. ownsDoc covers the case where
      // the new session is already active; the role/status fallback handles the
      // race where the Firestore SDK hasn't picked up the new auth token yet.
      allow create: if ownsDoc(userId)
        || (request.resource.data.role == 'member'
            && request.resource.data.status == 'pending')
        || isManager();
      allow update: if (ownsDoc(userId) && noRoleEscalation()) || (isManager() && noRoleEscalation());
      allow delete: if false;
    }

    // ── /groups ──────────────────────────────────────────────────────────

    match /groups/{groupId} {
      // Unauthenticated read allowed so the registration form dropdown
      // can list available groups without a Firebase session.
      allow read: if true;
      allow create, update: if isManager();
      allow delete: if isManager();
    }

    // ── /payments ────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isStaff()
        || (isMember() && resource.data.userId == request.auth.uid);
      // Members can submit their own pending payments (e.g. via PayModal).
      // Staff must confirm before status advances beyond 'pending'.
      allow create: if isStaff()
        || (isMember() && notSuspended()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.status == 'pending');
      allow update: if isManager() && resource.data.status != 'paid';
      allow delete: if false;
    }

    // ── /payouts ─────────────────────────────────────────────────────────

    match /payouts/{payoutId} {
      allow read: if isStaff()
        || (isMember() && resource.data.recipientId == request.auth.uid);
      allow create, update: if isManager();
      allow delete: if false;
    }

    // ── /messages/{groupId}/items ─────────────────────────────────────────

    match /messages/{groupId}/items/{messageId} {
      allow read: if isStaff()
        || (isMember() && request.auth.uid in
            get(/databases/$(database)/documents/groups/$(groupId)).data.members);
      allow create: if isStaff()
        || (isMember() && notSuspended() && request.auth.uid in
            get(/databases/$(database)/documents/groups/$(groupId)).data.members);
      // Messages are immutable once sent.
      allow update, delete: if false;
    }

    // ── /notifications ────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isManager()
        || (isRealAuth() && resource.data.userId == request.auth.uid);
      // Collectors can create notifications (send payment reminders).
      allow create: if isStaff();
      // Owner can mark as read; managers can update any field.
      allow update: if isManager()
        || (isRealAuth() && resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      // Owner or manager can delete a notification.
      allow delete: if isManager()
        || (isRealAuth() && resource.data.userId == request.auth.uid);
    }

    // ── /auditLogs ────────────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      // All client writes are denied. Entries are written exclusively by the
      // writeAuditLog Cloud Function using the Firebase Admin SDK, which bypasses
      // these rules — so logs cannot be forged, altered, or deleted by any client.
      allow write: if false;
    }

    // ── /receipts ─────────────────────────────────────────────────────────

    match /receipts/{receiptId} {
      allow read: if isManager()
        || (isMember() && resource.data.userId == request.auth.uid);
      allow create: if isManager();
      allow update, delete: if false;
    }

    // ── /settings ─────────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if isRealAuth();
      allow write: if isAdmin();
    }
  }
}
