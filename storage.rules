rules_version = '2';

// Production Storage rules for Excellent Susu.
//
// Paths:
//   users/{uid}/profile.{ext}             — owner or staff read; owner write
//   registration/{uid}/{kind}.{ext}       — owner write; staff read
//   payments/{paymentId}/proof.{ext}      — uploader (member) write; staff read

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isRealAuth() {
      return signedIn() && !isAnonymous();
    }

    function isOwner(uid) {
      return isRealAuth() && request.auth.uid == uid;
    }

    function validUpload() {
      return request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Profile photos — owner writes, any authenticated user reads
    match /users/{uid}/{file} {
      allow read:  if isRealAuth();
      allow write: if isOwner(uid) && validUpload();
    }

    // Registration documents (Ghana Card front/back, passport, selfie).
    // The uploader has no Firebase Auth account yet at the time of upload, so
    // we cannot check ownership. We restrict to safe content types and size only.
    match /registration/{userId}/{file} {
      allow read:  if isRealAuth();
      allow write: if validUpload();
    }

    // Payment proofs — any authenticated user uploads, staff reads
    match /payments/{paymentId}/{file} {
      allow read:  if isRealAuth();
      allow write: if isRealAuth() && validUpload();
    }

    // Chat media attachments
    match /messages/{groupId}/media/{file} {
      allow read:  if isRealAuth();
      allow write: if isRealAuth() && validUpload();
    }

    // Catch-all: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
